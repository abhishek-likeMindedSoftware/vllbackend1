<Project Sdk="Microsoft.NET.Sdk">

	<ItemGroup>
		<ProjectReference Include="..\LemonLaw.Application\LemonLaw.Application.csproj" />
		<ProjectReference Include="..\LemonLaw.Core\LemonLaw.Core.csproj" />
		<ProjectReference Include="..\LemonLaw.Shared\LemonLaw.Shared.csproj" />
	</ItemGroup>

	<ItemGroup>
		<PackageReference Include="Azure.Storage.Blobs" Version="12.27.0" />
		<PackageReference Include="DevExpress.ExpressApp" Version="25.2.*" />
		<PackageReference Include="DevExpress.ExpressApp.AuditTrail.EFCore" Version="25.2.*" />
		<PackageReference Include="DevExpress.ExpressApp.CodeAnalysis" Version="25.2.*" />
		<PackageReference Include="DevExpress.ExpressApp.EFCore" Version="25.2.*" />
		<PackageReference Include="DevExpress.ExpressApp.Security" Version="25.2.*" />
		<PackageReference Include="DevExpress.ExpressApp.Validation" Version="25.2.*" />
		<PackageReference Include="DevExpress.Persistent.Base" Version="25.2.*" />
		<PackageReference Include="DevExpress.Persistent.BaseImpl.EFCore" Version="25.2.*" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.4">
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
			<PrivateAssets>all</PrivateAssets>
		</PackageReference>
		<PackageReference Include="Microsoft.EntityFrameworkCore.SqlServer" Version="9.0.4" />
		<PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="9.0.4">
			<IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
			<PrivateAssets>all</PrivateAssets>
		</PackageReference>
	</ItemGroup>

	<PropertyGroup>
		<TargetFramework>net10.0</TargetFramework>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>
	</PropertyGroup>

</Project>
