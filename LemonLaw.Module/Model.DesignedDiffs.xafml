<?xml version="1.0" ?>
<Application Title="OCABR Workbench">
  <BOModel>
    <Class Name="DevExpress.Persistent.BaseImpl.EF.PermissionPolicy.PermissionPolicyUser" Caption="Base User" />
  </BOModel>
  <NavigationItems>
    <Items>
      <Item Id="Default" Caption="Admin" />
    </Items>
  </NavigationItems>
  <Options>
    <LayoutManagerOptions RequiredFieldMark="*" />
  </Options>
  <Views>
    <ListView Id="ApplicationUser_ListView" Caption="Users" />
    <DetailView Id="ReportDataV2_DetailView">
      <Layout>
        <LayoutGroup Id="Main" >
          <LayoutGroup Id="SimpleEditors" >
            <LayoutGroup Id="ReportDataV2" >
              <LayoutItem Id="DisplayName" ViewItem="DisplayName" Index="0" IsNewNode="True" Removed="True" />
              <LayoutItem Id="ParametersObjectType" ViewItem="ParametersObjectType" Index="1" IsNewNode="True" Removed="True" />
              <LayoutItem Id="DataTypeCaption" ViewItem="DataTypeCaption" Index="2" IsNewNode="True" Removed="True" />
              <LayoutItem Id="IsInplaceReport" Index="3" />
            </LayoutGroup>
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
    </DetailView>

    <!-- DealerResponse — read-only view for staff workbench.
         Layout is intentionally omitted — XAF auto-generates a clean
         vertical single-column layout from the entity's VisibleInDetailView
         attributes. The Actions block disables editing. -->
    <DetailView Id="DealerResponse_DetailView">
      <Actions>
        <ActionDesign>
          <Actions>
            <Action Id="Save"         Active="False" />
            <Action Id="SaveAndClose" Active="False" />
            <Action Id="SaveAndNew"   Active="False" />
            <Action Id="Delete"       Active="False" />
          </Actions>
        </ActionDesign>
      </Actions>
    </DetailView>

    <!-- AssignCaseInput — filter SelectedUser lookup to CASE_MANAGER role only -->
    <DetailView Id="AssignCaseInput_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="SelectedUser" PropertyName="SelectedUser"
                        DataSourceCriteria="Roles[Name = 'CASE_MANAGER']"
                        IsNewNode="True" />
      </Items>
    </DetailView>

  </Views>
</Application>
