@page "/dealer"
@using LemonLaw.Blazor.Server.Models
@using System.Net.Http.Json
@inject NavigationManager Nav
@inject IHttpClientFactory HttpClientFactory
@inject ILogger<DealerPortal> Logger

<PageTitle>Dealer Response Portal — OCABR Lemon Law</PageTitle>

<div class="dealer-portal-wrapper">

    <!-- ── Header ── -->
    <header class="dealer-header">
        <div class="dealer-header-inner">
            <div class="dealer-logo">
                <div class="ma-seal">MA</div>
                <div>
                    <p class="dealer-header-agency">Commonwealth of Massachusetts</p>
                    <p class="dealer-header-title">OCABR — Vehicle Lemon Law Program</p>
                </div>
            </div>
            <span class="dealer-header-badge">
                <i class="fa-solid fa-building-columns" style="margin-right:5px;"></i>Dealer Response Portal
            </span>
        </div>
    </header>

    <!-- ── Main content ── -->
    <main class="dealer-content">

        @if (_loading)
        {
            <div style="text-align:center; padding:80px 24px;">
                <i class="fa-solid fa-spinner fa-spin" style="font-size:2rem; color:var(--theme-color);"></i>
                <p style="margin-top:16px; color:var(--ms-gray-dark); font-size:var(--text-sm);">Loading case information…</p>
            </div>
        }
        else if (!string.IsNullOrEmpty(_errorMessage))
        {
            <div class="dealer-card" style="max-width:560px; margin:0 auto; text-align:center; padding:48px 40px;">
                <div class="dealer-icon-circle" style="background:rgba(220,53,69,0.08);">
                    <i class="fa-solid fa-triangle-exclamation" style="color:#dc3545;"></i>
                </div>
                <h2 class="dealer-card-title" style="color:#dc3545; margin-top:20px;">Access Error</h2>
                <p class="dealer-card-subtitle">@_errorMessage</p>
                <p style="font-size:var(--text-xs); color:var(--ms-gray-dark);">
                    If you believe this is an error, please contact OCABR at
                    <a href="mailto:ocabr@mass.gov">ocabr@mass.gov</a> or (617) 973-8787.
                </p>
            </div>
        }
        else if (!_tokenValidated)
        {
            <!-- Landing / access gate -->
            <div class="dealer-card" style="max-width:580px; margin:0 auto; text-align:center; padding:48px 40px;">
                <div class="dealer-icon-circle">
                    <i class="fa-solid fa-envelope-open-text"></i>
                </div>
                <h1 class="dealer-card-title" style="margin-top:20px;">Dealer Response Portal</h1>
                <p class="dealer-card-subtitle">
                    You have received a Lemon Law outreach notice from the Office of Consumer Affairs
                    and Business Regulation (OCABR). Please review the consumer's application and
                    submit your formal response.
                </p>

                @if (_caseSummary != null)
                {
                    <div class="dealer-info-box">
                        <div style="display:grid; grid-template-columns:1fr 1fr; gap:8px 20px; text-align:left;">
                            <div>
                                <p class="dealer-label">Case Number</p>
                                <p style="font-weight:700; color:var(--theme-color); font-size:var(--text-sm); margin:0;">@_caseSummary.CaseNumber</p>
                            </div>
                            <div>
                                <p class="dealer-label">Consumer</p>
                                <p style="font-weight:600; font-size:var(--text-sm); margin:0;">@_caseSummary.ConsumerName</p>
                            </div>
                            <div>
                                <p class="dealer-label">Vehicle</p>
                                <p style="font-weight:600; font-size:var(--text-sm); margin:0;">@_caseSummary.VehicleYMM</p>
                            </div>
                            <div>
                                <p class="dealer-label">Response Deadline</p>
                                <span class="dealer-deadline-badge">
                                    <i class="fa-solid fa-calendar-xmark"></i>
                                    @_caseSummary.ResponseDeadline.ToString("MMM d, yyyy")
                                </span>
                            </div>
                        </div>
                    </div>
                }

                <button class="dealer-btn-primary" @onclick="ProceedToForm" style="width:100%; justify-content:center;">
                    <i class="fa-solid fa-arrow-right"></i> Access Case &amp; Respond
                </button>
            </div>
        }
        else if (!_submitted)
        {
            <div style="max-width:900px; margin:0 auto;">

                <!-- Case summary card -->
                <div class="dealer-card" style="margin-bottom:20px;">
                    <div class="dealer-section-header">
                        <i class="fa-solid fa-file-lines"></i>
                        <h2>Case Summary</h2>
                        @if (_caseSummary != null)
                        {
                            <span class="dealer-deadline-badge" style="margin-left:auto;">
                                <i class="fa-solid fa-calendar-xmark"></i>
                                Deadline: @_caseSummary.ResponseDeadline.ToString("MMMM d, yyyy")
                            </span>
                        }
                    </div>

                    @if (_caseSummary != null)
                    {
                        <div class="dealer-summary-grid" style="margin-bottom:20px;">
                            <div class="dealer-summary-item">
                                <span class="dealer-label">Case Number</span>
                                <strong class="dealer-value theme-value">@_caseSummary.CaseNumber</strong>
                            </div>
                            <div class="dealer-summary-item">
                                <span class="dealer-label">Consumer</span>
                                <strong class="dealer-value">@_caseSummary.ConsumerName</strong>
                            </div>
                            <div class="dealer-summary-item">
                                <span class="dealer-label">Vehicle</span>
                                <strong class="dealer-value">@_caseSummary.VehicleYMM</strong>
                            </div>
                            <div class="dealer-summary-item">
                                <span class="dealer-label">VIN</span>
                                <strong class="dealer-value" style="font-family:monospace; letter-spacing:1px;">@_caseSummary.VIN</strong>
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_caseSummary.NarrativeStatement))
                        {
                            <div class="dealer-panel">
                                <p class="dealer-panel-title">
                                    <i class="fa-solid fa-quote-left" style="margin-right:5px; color:var(--theme-color);"></i>
                                    Consumer's Statement
                                </p>
                                <p style="font-size:var(--text-sm); line-height:1.75; color:#374151; margin:0; font-style:italic;">
                                    "@_caseSummary.NarrativeStatement"
                                </p>
                            </div>
                        }

                        @if (_caseSummary.Defects?.Count > 0)
                        {
                            <div class="dealer-panel" style="margin-top:12px;">
                                <p class="dealer-panel-title">
                                    <i class="fa-solid fa-wrench" style="margin-right:5px; color:var(--theme-color);"></i>
                                    Reported Defects (@_caseSummary.Defects.Count)
                                </p>
                                @foreach (var defect in _caseSummary.Defects)
                                {
                                    <div class="dealer-defect-item">
                                        <span style="font-weight:600; color:var(--theme-color);">
                                            @defect.DefectCategory.Replace("_", " ")
                                        </span>
                                        <span style="color:var(--ms-gray-dark);"> — </span>
                                        @defect.DefectDescription
                                    </div>
                                }
                            </div>
                        }

                        @if (_caseSummary.RepairAttempts?.Count > 0)
                        {
                            <div class="dealer-panel" style="margin-top:12px;">
                                <p class="dealer-panel-title">
                                    <i class="fa-solid fa-screwdriver-wrench" style="margin-right:5px; color:var(--theme-color);"></i>
                                    Consumer's Repair History (@_caseSummary.RepairAttempts.Count attempts)
                                </p>
                                @foreach (var repair in _caseSummary.RepairAttempts.OrderBy(r => r.SortOrder))
                                {
                                    <div class="dealer-repair-item">
                                        <div style="display:flex; justify-content:space-between; flex-wrap:wrap; gap:4px; margin-bottom:4px;">
                                            <strong>@repair.RepairFacilityName</strong>
                                            <span style="color:var(--ms-gray-dark); font-size:var(--text-xs);">@repair.RepairDate</span>
                                        </div>
                                        @if (!string.IsNullOrWhiteSpace(repair.RepairFacilityAddr))
                                        {
                                            <div style="color:var(--ms-gray-dark); font-size:var(--text-xs); margin-bottom:4px;">
                                                <i class="fa-solid fa-location-dot" style="margin-right:3px;"></i>@repair.RepairFacilityAddr
                                            </div>
                                        }
                                        <div style="margin-bottom:6px; color:#374151;">@repair.DefectsAddressed</div>
                                        <div class="dealer-repair-meta">
                                            @if (repair.RoNumber != null)
                                            {
                                                <span><i class="fa-solid fa-hashtag" style="margin-right:2px;"></i>RO @repair.RoNumber</span>
                                            }
                                            @if (repair.MileageAtRepair.HasValue)
                                            {
                                                <span><i class="fa-solid fa-gauge" style="margin-right:3px;"></i>@repair.MileageAtRepair.Value.ToString("N0") mi</span>
                                            }
                                            @if (repair.DaysOutOfService.HasValue)
                                            {
                                                <span><i class="fa-solid fa-calendar-days" style="margin-right:3px;"></i>@repair.DaysOutOfService days out of service</span>
                                            }
                                            <span style="font-weight:600; color:@(repair.RepairSuccessful ? "#388557" : "#dc3545");">
                                                <i class="fa-solid @(repair.RepairSuccessful ? "fa-check-circle" : "fa-circle-xmark")" style="margin-right:3px;"></i>
                                                @(repair.RepairSuccessful ? "Resolved" : "Not resolved")
                                            </span>
                                        </div>
                                    </div>
                                }
                            </div>
                        }
                    }
                </div>

                <!-- Response form card -->
                <div class="dealer-card">
                    <div class="dealer-section-header">
                        <i class="fa-solid fa-pen-to-square"></i>
                        <h2>Your Response</h2>
                    </div>

                    <!-- Responder info -->
                    <p style="font-weight:700; font-size:var(--text-sm); color:var(--dark-color); margin:0 0 14px; padding-bottom:8px; border-bottom:1px solid #e5e7eb;">
                        Responder Information
                    </p>
                    <div class="dealer-form-grid" style="margin-bottom:24px;">
                        <div class="dealer-form-group">
                            <label class="dealer-form-label">Your Name <span class="required">*</span></label>
                            <input type="text" @bind="_response.ResponderName" class="dealer-input" placeholder="John Doe" />
                        </div>
                        <div class="dealer-form-group">
                            <label class="dealer-form-label">Your Title</label>
                            <input type="text" @bind="_response.ResponderTitle" class="dealer-input" placeholder="Service Manager" />
                        </div>
                        <div class="dealer-form-group">
                            <label class="dealer-form-label">Your Email <span class="required">*</span></label>
                            <input type="email" @bind="_response.ResponderEmail" class="dealer-input" placeholder="service@dealership.com" />
                        </div>
                        <div class="dealer-form-group">
                            <label class="dealer-form-label">Your Phone</label>
                            <input type="tel" @bind="_response.ResponderPhone" class="dealer-input" placeholder="(617) 555-0100" />
                        </div>
                    </div>

                    <!-- Position & narrative -->
                    <p style="font-weight:700; font-size:var(--text-sm); color:var(--dark-color); margin:0 0 14px; padding-bottom:8px; border-bottom:1px solid #e5e7eb;">
                        Response Details
                    </p>
                    <div class="dealer-form-grid">
                        <div class="dealer-form-group dealer-form-full">
                            <label class="dealer-form-label">Dealer Position <span class="required">*</span></label>
                            <select @bind="_response.DealerPosition" class="dealer-input">
                                <option value="">— Select your position —</option>
                                <option value="DISPUTES_CLAIM">We dispute the consumer's claim</option>
                                <option value="ACKNOWLEDGES_DEFECT">We acknowledge the defect</option>
                                <option value="OFFERS_SETTLEMENT">We offer a settlement</option>
                                <option value="RESOLVED_PRIOR">This was resolved prior to this filing</option>
                                <option value="VEHICLE_NOT_PURCHASED_HERE">Vehicle was not purchased at this dealership</option>
                                <option value="OTHER">Other</option>
                            </select>
                        </div>

                        @if (_response.DealerPosition == "OFFERS_SETTLEMENT")
                        {
                            <div class="dealer-form-group">
                                <label class="dealer-form-label">Settlement Amount ($)</label>
                                <input type="number" @bind="_response.SettlementOffer" class="dealer-input" placeholder="0.00" />
                            </div>
                            <div class="dealer-form-group">
                                <label class="dealer-form-label">Settlement Details</label>
                                <input type="text" @bind="_response.SettlementDetails" class="dealer-input" placeholder="Describe the proposed settlement…" />
                            </div>
                        }

                        <div class="dealer-form-group dealer-form-full">
                            <label class="dealer-form-label">Response Narrative <span class="required">*</span></label>
                            <textarea @bind="_response.ResponseNarrative" class="dealer-input" rows="6"
                                      placeholder="Provide your detailed response to the consumer's claims…"
                                      style="resize:vertical;"></textarea>
                            <p class="dealer-hint">Minimum 50 characters required.</p>
                        </div>

                        <div class="dealer-form-group dealer-form-full">
                            <label class="dealer-form-label">Repair History Notes</label>
                            <textarea @bind="_response.RepairHistoryNotes" class="dealer-input" rows="3"
                                      placeholder="Summarize the repair attempts performed at your facility…"
                                      style="resize:vertical;"></textarea>
                        </div>
                    </div>

                    <!-- Certification -->
                    <div class="dealer-cert-box">
                        <p style="font-weight:700; font-size:var(--text-sm); color:var(--dark-color); margin:0 0 14px;">
                            <i class="fa-solid fa-shield-halved" style="margin-right:6px; color:var(--theme-color);"></i>
                            Certification &amp; Signature
                        </p>
                        <label style="display:flex; align-items:flex-start; gap:12px; cursor:pointer; margin-bottom:16px;">
                            <input type="checkbox" @bind="_response.CertificationAccepted"
                                   style="margin-top:3px; width:16px; height:16px; accent-color:var(--theme-color); flex-shrink:0;" />
                            <span style="font-size:var(--text-sm); line-height:1.7; color:#374151;">
                                I certify that the information provided in this response is accurate and complete to the best of my knowledge,
                                and that I am authorized to submit this response on behalf of the dealership.
                            </span>
                        </label>
                        <div style="max-width:380px;">
                            <label class="dealer-form-label">
                                Electronic Signature — Type your full legal name <span class="required">*</span>
                            </label>
                            <input type="text" @bind="_response.CertifierFullName" class="dealer-input"
                                   placeholder="John Doe" style="font-style:italic; font-size:1.05rem;" />
                        </div>
                    </div>

                    @if (!string.IsNullOrEmpty(_validationError))
                    {
                        <div class="dealer-alert-error" role="alert">
                            <i class="fa-solid fa-triangle-exclamation"></i> @_validationError
                        </div>
                    }

                    <div class="dealer-nav-divider">
                        <span style="font-size:var(--text-xs); color:var(--ms-gray-dark);">
                            All fields marked <span style="color:#dc3545;">*</span> are required.
                        </span>
                        <button class="dealer-btn-primary" @onclick="SubmitResponse" disabled="@_submitting">
                            @if (_submitting)
                            {
                                <i class="fa-solid fa-spinner fa-spin"></i>
                                <span>Submitting…</span>
                            }
                            else
                            {
                                <i class="fa-solid fa-paper-plane"></i>
                                <span>Submit Response</span>
                            }
                        </button>
                    </div>
                </div>

            </div>
        }
        else
        {
            <!-- Success screen -->
            <div class="dealer-card" style="max-width:560px; margin:0 auto; text-align:center; padding:48px 40px;">
                <div class="dealer-icon-circle" style="background:rgba(56,133,87,0.08);">
                    <i class="fa-solid fa-check" style="color:#388557;"></i>
                </div>
                <h2 class="dealer-card-title" style="color:#388557; margin-top:20px;">Response Submitted</h2>
                <p class="dealer-card-subtitle">
                    Thank you. Your response to case
                    <strong style="color:var(--theme-color);">@(_caseSummary?.CaseNumber ?? "")</strong>
                    has been received by OCABR.
                </p>
                <div class="dealer-info-box">
                    <p><strong>Submitted by:</strong> @_response.ResponderName</p>
                    <p><strong>Position:</strong> @_response.DealerPosition?.Replace("_", " ")</p>
                    <p><strong>Submitted at:</strong> @DateTime.Now.ToString("MMMM d, yyyy h:mm tt")</p>
                </div>
                <p style="font-size:var(--text-xs); color:var(--ms-gray-dark); line-height:1.6;">
                    OCABR staff will review your response and contact you if further information is needed.
                    For questions, contact <a href="mailto:ocabr@mass.gov">ocabr@mass.gov</a> or (617) 973-8787.
                </p>
            </div>
        }

    </main>

    <!-- ── Footer ── -->
    <footer class="dealer-footer">
        <p>© @DateTime.Now.Year Commonwealth of Massachusetts — Office of Consumer Affairs and Business Regulation</p>
    </footer>

</div>

@code {
    private bool _loading = true;
    private bool _tokenValidated = false;
    private bool _submitted = false;
    private bool _submitting = false;
    private string _validationError = string.Empty;
    private string _errorMessage = string.Empty;

    private string? _outreachId;
    private string? _token;

    private DealerResponseModel _response = new();
    private DealerCaseSummaryModel? _caseSummary;

    protected override async Task OnInitializedAsync()
    {
        var uri = new Uri(Nav.Uri);
        var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
        _outreachId = query["outreachId"];
        _token = query["token"];

        if (string.IsNullOrWhiteSpace(_outreachId) || string.IsNullOrWhiteSpace(_token))
        {
            _errorMessage = "Invalid access link. Please use the link from your OCABR notification email.";
            _loading = false;
            return;
        }

        await LoadCaseSummaryAsync();
        _loading = false;
    }

    private async Task LoadCaseSummaryAsync()
    {
        try
        {
            var client = HttpClientFactory.CreateClient("LemonLawApi");
            var url = $"api/dealer-portal/case-summary?outreachId={_outreachId}&token={Uri.EscapeDataString(_token!)}";
            var response = await client.GetFromJsonAsync<ApiResponse<DealerCaseSummaryModel>>(url);

            if (response?.Success == true && response.Data != null)
                _caseSummary = response.Data;
            else
                _errorMessage = response?.Message ?? "Unable to load case information. Your link may have expired.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error loading dealer case summary for outreach {Id}", _outreachId);
            _errorMessage = "Unable to connect to the server. Please try again later.";
        }
    }

    private void ProceedToForm() => _tokenValidated = true;

    private async Task SubmitResponse()
    {
        _validationError = string.Empty;

        if (string.IsNullOrWhiteSpace(_response.ResponderName))
        { _validationError = "Your name is required."; return; }
        if (string.IsNullOrWhiteSpace(_response.ResponderEmail))
        { _validationError = "Your email is required."; return; }
        if (string.IsNullOrWhiteSpace(_response.DealerPosition))
        { _validationError = "Please select your dealer position."; return; }
        if (string.IsNullOrWhiteSpace(_response.ResponseNarrative) || _response.ResponseNarrative.Length < 50)
        { _validationError = "Response narrative must be at least 50 characters."; return; }
        if (!_response.CertificationAccepted)
        { _validationError = "You must certify the accuracy of your response."; return; }
        if (string.IsNullOrWhiteSpace(_response.CertifierFullName))
        { _validationError = "Electronic signature (full name) is required."; return; }

        _submitting = true;
        try
        {
            var client = HttpClientFactory.CreateClient("LemonLawApi");
            var url = $"api/dealer-portal/response?outreachId={_outreachId}&token={Uri.EscapeDataString(_token!)}";

            var payload = new
            {
                responderName      = _response.ResponderName,
                responderTitle     = _response.ResponderTitle,
                responderEmail     = _response.ResponderEmail,
                responderPhone     = _response.ResponderPhone,
                dealerPosition     = _response.DealerPosition,
                responseNarrative  = _response.ResponseNarrative,
                repairHistoryNotes = _response.RepairHistoryNotes,
                settlementOffer    = _response.SettlementOffer,
                settlementDetails  = _response.SettlementDetails,
                certificationAccepted = _response.CertificationAccepted,
                certifierFullName  = _response.CertifierFullName
            };

            var httpResponse = await client.PostAsJsonAsync(url, payload);
            var result = await httpResponse.Content.ReadFromJsonAsync<ApiResponse<bool>>();

            if (result?.Success == true)
                _submitted = true;
            else
                _validationError = result?.Message ?? "Submission failed. Please try again.";
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Error submitting dealer response for outreach {Id}", _outreachId);
            _validationError = "Unable to submit response. Please check your connection and try again.";
        }
        finally
        {
            _submitting = false;
        }
    }

    // ── Local models ──────────────────────────────────────────────────────────

    private class ApiResponse<T>
    {
        public bool Success { get; set; }
        public string? Message { get; set; }
        public T? Data { get; set; }
    }

    private class DealerCaseSummaryModel
    {
        public string CaseNumber { get; set; } = string.Empty;
        public string ConsumerName { get; set; } = string.Empty;
        public string VehicleYMM { get; set; } = string.Empty;
        public string VIN { get; set; } = string.Empty;
        public DateOnly ResponseDeadline { get; set; }
        public string NarrativeStatement { get; set; } = string.Empty;
        public List<DefectItem> Defects { get; set; } = new();
        public List<RepairAttemptItem> RepairAttempts { get; set; } = new();
    }

    private class DefectItem
    {
        public string DefectDescription { get; set; } = string.Empty;
        public string DefectCategory { get; set; } = string.Empty;
    }

    private class RepairAttemptItem
    {
        public string RepairDate { get; set; } = string.Empty;
        public string RepairFacilityName { get; set; } = string.Empty;
        public string? RepairFacilityAddr { get; set; }
        public string? RoNumber { get; set; }
        public int? MileageAtRepair { get; set; }
        public string DefectsAddressed { get; set; } = string.Empty;
        public bool RepairSuccessful { get; set; }
        public int? DaysOutOfService { get; set; }
        public int SortOrder { get; set; }
    }
}
