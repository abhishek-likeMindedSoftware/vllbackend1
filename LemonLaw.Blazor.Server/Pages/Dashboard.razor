@using LemonLaw.Application.Interfaces
@using LemonLaw.Application.Repositories
@using LemonLaw.Core.Entities
@using LemonLaw.Core.Enums
@using Microsoft.Extensions.DependencyInjection
@inject IServiceProvider ServiceProvider
@inject Microsoft.AspNetCore.Http.IHttpContextAccessor HttpContextAccessor

<PageTitle>Dashboard — OCABR Lemon Law Workbench</PageTitle>

<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

<div class="d-wrap">

    <!-- Page header -->
    <div class="d-header">
        <div>
            <h1 class="d-title">@(_isCaseManagerView ? "My Cases" : "Workbench Overview")</h1>
            <p class="d-subtitle">
                @DateTime.Now.ToString("dddd, MMMM d, yyyy") &nbsp;·&nbsp; OCABR Vehicle Lemon Law Program
                @if (_isCaseManagerView)
                {
                    <span>&nbsp;·&nbsp; <strong style="color:#0265A3;">Showing your assigned cases</strong></span>
                }
            </p>
        </div>
    </div>

    @if (_loading)
    {
        <div class="d-loading">
            <span class="d-spinner"></span>
            <span>Loading…</span>
        </div>
    }
    else if (_loadError != null)
    {
        <div class="d-error">
            <strong>Could not load dashboard data:</strong> @_loadError
        </div>
    }
    else
    {
        <!-- KPI row — 3 per row, 2 rows -->
        <div class="d-kpi-row">
            <div class="d-kpi d-kpi-orange">
                <div class="d-kpi-icon-wrap" style="background:rgba(234,88,12,0.08);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#ea580c" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div>
                    <p class="d-kpi-label">@(_isCaseManagerView ? "My Open Cases" : "Open Cases")</p>
                    <p class="d-kpi-num" style="color:#ea580c;">@_totalOpen</p>
                    <p class="d-kpi-sub">@(_isCaseManagerView ? "Assigned to you" : "Active in system")</p>
                </div>
            </div>
            <div class="d-kpi d-kpi-amber">
                <div class="d-kpi-icon-wrap" style="background:rgba(217,119,6,0.08);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
                </div>
                <div>
                    <p class="d-kpi-label">Pending Review</p>
                    <p class="d-kpi-num" style="color:#d97706;">@_pendingReview</p>
                    <p class="d-kpi-sub">Awaiting staff action</p>
                </div>
            </div>
            <div class="d-kpi d-kpi-red">
                <div class="d-kpi-icon-wrap" style="background:rgba(220,38,38,0.08);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#dc2626" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
                </div>
                <div>
                    <p class="d-kpi-label">Aging Alerts</p>
                    <p class="d-kpi-num" style="color:#dc2626;">@_agingAlerts</p>
                    <p class="d-kpi-sub">Open &gt; 30 days</p>
                </div>
            </div>
            <div class="d-kpi d-kpi-green">
                <div class="d-kpi-icon-wrap" style="background:rgba(22,163,74,0.08);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#16a34a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                </div>
                <div>
                    <p class="d-kpi-label">Submitted This Month</p>
                    <p class="d-kpi-num" style="color:#16a34a;">@_submittedThisMonth</p>
                    <p class="d-kpi-sub">New applications</p>
                </div>
            </div>
            <div class="d-kpi d-kpi-blue">
                <div class="d-kpi-icon-wrap" style="background:rgba(37,99,235,0.08);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
                </div>
                <div>
                    <p class="d-kpi-label">Awaiting Dealer</p>
                    <p class="d-kpi-num" style="color:#2563eb;">@_awaitingDealer</p>
                    <p class="d-kpi-sub">Outreach sent, no reply</p>
                </div>
            </div>
            <div class="d-kpi d-kpi-purple">
                <div class="d-kpi-icon-wrap" style="background:rgba(124,58,237,0.08);">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#7c3aed" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
                </div>
                <div>
                    <p class="d-kpi-label">Hearings Scheduled</p>
                    <p class="d-kpi-num" style="color:#7c3aed;">@_hearingsScheduled</p>
                    <p class="d-kpi-sub">Upcoming</p>
                </div>
            </div>
        </div>

        <!-- Application type strip -->
        <div class="d-type-strip">
            <div class="d-type-item">
                <span class="d-type-dot" style="background:#1d4ed8;"></span>
                <span class="d-type-label">New Car Lemon Law</span>
                <span class="d-type-count">@_byType.GetValueOrDefault("NEW_CAR", 0)</span>
            </div>
            <div class="d-type-divider"></div>
            <div class="d-type-item">
                <span class="d-type-dot" style="background:#6d28d9;"></span>
                <span class="d-type-label">Used Car Warranty</span>
                <span class="d-type-count">@_byType.GetValueOrDefault("USED_CAR", 0)</span>
            </div>
            <div class="d-type-divider"></div>
            <div class="d-type-item">
                <span class="d-type-dot" style="background:#be185d;"></span>
                <span class="d-type-label">Leased Vehicle</span>
                <span class="d-type-count">@_byType.GetValueOrDefault("LEASED", 0)</span>
            </div>
        </div>

        <!-- Two-column: status + activity -->
        <div class="d-two-col">

            <!-- Cases by Status -->
            <div class="d-card">
                <p class="d-card-title">Cases by Status</p>
                <div class="d-status-list">
                    @foreach (var item in _statusBreakdown)
                    {
                        <div class="d-status-row">
                            <span class="d-status-label">@item.Key.Replace("_", " ")</span>
                            <div class="d-bar-track">
                                <div class="d-bar-fill" style="width:@GetBarWidth(item.Value)%; background:@GetStatusBarColor(item.Key);"></div>
                            </div>
                            <span class="d-status-count">@item.Value</span>
                        </div>
                    }
                    @if (!_statusBreakdown.Any())
                    {
                        <p class="d-empty">No open cases.</p>
                    }
                </div>
            </div>

            <!-- Recent Activity -->
            <div class="d-card">
                <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;">
                    <p class="d-card-title" style="margin:0;">Recent Activity</p>
                    <span class="d-activity-count">@_recentActivity.Count events</span>
                </div>
                <div class="d-activity-scroll">
                    @foreach (var evt in _recentActivity)
                    {
                        <div class="d-activity-row">
                            <span class="d-activity-dot @GetEventDotClass(evt.EventType)"></span>
                            <div class="d-activity-body">
                                <p class="d-activity-desc">@evt.Description</p>
                                <p class="d-activity-meta">
                                    @evt.ActorDisplayName
                                    <span class="d-activity-sep">·</span>
                                    @evt.EventTimestamp.ToLocalTime().ToString("MMM d, h:mm tt")
                                </p>
                            </div>
                        </div>
                    }
                    @if (!_recentActivity.Any())
                    {
                        <p class="d-empty">No recent activity.</p>
                    }
                </div>
            </div>

        </div>
    }
</div>

<style>
    /* ── Font ──────────────────────────────────────────────────────────────── */
    .d-wrap, .d-wrap * {
        font-family: 'Inter', 'Segoe UI', system-ui, sans-serif;
        box-sizing: border-box;
    }

    /* ── Wrapper ───────────────────────────────────────────────────────────── */
    .d-wrap {
        padding: 28px 32px;
        background: #ffffff;
        min-height: 100%;
    }

    /* ── Header ────────────────────────────────────────────────────────────── */
    .d-header { margin-bottom: 28px; }
    .d-title {
        font-size: 1.375rem;
        font-weight: 700;
        color: #0f172a;
        margin: 0 0 4px;
        letter-spacing: -0.02em;
    }
    .d-subtitle {
        font-size: 0.8125rem;
        color: #4b5563;
        margin: 0;
        font-weight: 400;
    }

    /* ── Loading / Error ───────────────────────────────────────────────────── */
    .d-loading {
        display: flex; align-items: center; gap: 10px;
        color: #64748b; padding: 48px 0; font-size: 0.875rem;
    }
    .d-spinner {
        width: 16px; height: 16px;
        border: 2px solid #e2e8f0;
        border-top-color: #0f172a;
        border-radius: 50%;
        animation: d-spin 0.7s linear infinite;
        flex-shrink: 0;
    }
    @@keyframes d-spin { to { transform: rotate(360deg); } }
    .d-error {
        background: #fef2f2; border: 1px solid #fecaca;
        border-radius: 8px; padding: 14px 18px;
        color: #991b1b; font-size: 0.875rem; margin-bottom: 24px;
    }
    .d-empty { color: #94a3b8; font-size: 0.8125rem; margin: 0; }

    /* ── KPI Row — 3 per row, 2 rows ──────────────────────────────────────── */
    .d-kpi-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 14px;
        margin-bottom: 16px;
    }
    .d-kpi {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 18px 18px;
        box-shadow: 0 1px 3px rgba(15,23,42,0.05);
        display: flex;
        align-items: flex-start;
        gap: 14px;
        border-left-width: 3px;
        transition: box-shadow 0.15s;
    }
    .d-kpi:hover { box-shadow: 0 4px 12px rgba(15,23,42,0.08); }
    .d-kpi-orange { border-left-color: #ea580c; }
    .d-kpi-amber  { border-left-color: #d97706; }
    .d-kpi-red    { border-left-color: #dc2626; }
    .d-kpi-green  { border-left-color: #16a34a; }
    .d-kpi-blue   { border-left-color: #2563eb; }
    .d-kpi-purple { border-left-color: #7c3aed; }
    .d-kpi-icon-wrap {
        width: 38px; height: 38px; border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        flex-shrink: 0;
    }
    .d-kpi-label {
        font-size: 0.6875rem;
        font-weight: 700;
        color: #374151;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin: 0 0 4px;
    }
    .d-kpi-num {
        font-size: 1.75rem;
        font-weight: 800;
        color: #0f172a;
        margin: 0 0 3px;
        line-height: 1;
        letter-spacing: -0.03em;
    }
    .d-kpi-sub {
        font-size: 0.6875rem;
        color: #6b7280;
        margin: 0;
        font-weight: 500;
    }

    /* ── Application Type Strip ────────────────────────────────────────────── */
    .d-type-strip {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 16px 24px;
        display: flex;
        align-items: center;
        gap: 0;
        margin-bottom: 16px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04);
    }
    .d-type-item {
        display: flex; align-items: center; gap: 10px; flex: 1;
    }
    .d-type-dot {
        width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0;
    }
    .d-type-label {
        font-size: 0.8125rem; color: #475569; font-weight: 500; flex: 1;
    }
    .d-type-count {
        font-size: 1.125rem; font-weight: 700; color: #0f172a;
        letter-spacing: -0.02em;
    }
    .d-type-divider {
        width: 1px; height: 32px; background: #e2e8f0; margin: 0 24px;
    }

    /* ── Two-column ────────────────────────────────────────────────────────── */
    .d-two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 16px;
        align-items: start;
    }
    .d-card {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 10px;
        padding: 20px 22px;
        box-shadow: 0 1px 2px rgba(15,23,42,0.04);
        height: 340px;
        display: flex;
        flex-direction: column;
    }
    .d-card-title {
        font-size: 0.8125rem;
        font-weight: 600;
        color: #0f172a;
        margin: 0 0 16px;
        letter-spacing: -0.01em;
    }

    /* ── Status bars ───────────────────────────────────────────────────────── */
    .d-status-list {
        display: flex; flex-direction: column; gap: 12px;
        flex: 1; overflow-y: auto;
    }
    .d-status-row { display: flex; align-items: center; gap: 10px; }
    .d-status-label {
        font-size: 0.6875rem; font-weight: 600; color: #475569;
        text-transform: uppercase; letter-spacing: 0.05em;
        min-width: 140px; white-space: nowrap;
    }
    .d-bar-track {
        flex: 1; height: 7px; background: #f1f5f9;
        border-radius: 99px; overflow: hidden;
    }
    .d-bar-fill {
        height: 100%; background: #ea580c;
        border-radius: 99px; transition: width 0.5s ease;
    }
    .d-status-count {
        font-size: 0.875rem; font-weight: 700; color: #0f172a;
        min-width: 20px; text-align: right;
    }

    /* ── Activity feed ─────────────────────────────────────────────────────── */
    .d-activity-count {
        font-size: 0.6875rem; color: #94a3b8; font-weight: 500;
    }
    .d-activity-scroll {
        flex: 1; overflow-y: auto; padding-right: 2px;
    }
    .d-activity-scroll::-webkit-scrollbar { width: 3px; }
    .d-activity-scroll::-webkit-scrollbar-track { background: transparent; }
    .d-activity-scroll::-webkit-scrollbar-thumb { background: #e2e8f0; border-radius: 99px; }
    .d-activity-row {
        display: flex; align-items: flex-start; gap: 10px;
        padding: 9px 0;
        border-bottom: 1px solid #f8fafc;
    }
    .d-activity-row:last-child { border-bottom: none; }
    .d-activity-dot {
        width: 7px; height: 7px; border-radius: 50%;
        margin-top: 5px; flex-shrink: 0;
    }
    .d-dot-dark   { background: #ea580c; }
    .d-dot-mid    { background: #2563eb; }
    .d-dot-light  { background: #cbd5e1; }
    .d-activity-body { flex: 1; }
    .d-activity-desc {
        font-size: 0.8rem; color: #1e293b; margin: 0 0 2px;
        line-height: 1.45; font-weight: 500;
    }
    .d-activity-meta {
        font-size: 0.6875rem; color: #94a3b8; margin: 0;
        display: flex; align-items: center; gap: 4px;
    }
    .d-activity-sep { color: #cbd5e1; }

    /* ── Responsive ────────────────────────────────────────────────────────── */
    @@media (max-width: 1100px) {
        .d-kpi-row { grid-template-columns: repeat(3, 1fr); }
    }
    @@media (max-width: 800px) {
        .d-kpi-row { grid-template-columns: repeat(2, 1fr); }
        .d-two-col { grid-template-columns: 1fr; }
        .d-type-strip { flex-direction: column; align-items: flex-start; gap: 12px; }
        .d-type-divider { width: 100%; height: 1px; margin: 0; }
    }</style>

@code {
    private bool _loading = true;
    private string? _loadError;
    private bool _isCaseManagerView = false;
    private string? _currentUserId;

    private int _totalOpen;
    private int _pendingReview;
    private int _agingAlerts;
    private int _submittedThisMonth;
    private int _awaitingDealer;
    private int _hearingsScheduled;

    private Dictionary<string, int> _statusBreakdown = new();
    private Dictionary<string, int> _byType = new();
    private List<CaseEvent> _recentActivity = new();

    private static readonly ApplicationStatus[] ClosedStatuses =
        { ApplicationStatus.CLOSED, ApplicationStatus.WITHDRAWN };

    protected override async Task OnInitializedAsync()
    {
        await LoadDataAsync();
    }

    private async Task LoadDataAsync()
    {
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var appRepo = scope.ServiceProvider
                .GetRequiredService<IApplicationRepository>();
            var eventRepo = scope.ServiceProvider
                .GetRequiredService<IGenericRepository<CaseEvent>>();

            // Detect current user role via XAF SecuritySystem (reliable in Blazor server context)
            _currentUserId = null;
            _isCaseManagerView = false;

            if (DevExpress.ExpressApp.SecuritySystem.CurrentUser is LemonLaw.Core.Entities.ApplicationUser xafUser)
            {
                _currentUserId = xafUser.UserName;
                _isCaseManagerView = xafUser.Roles.Any(r => r.Name == "CASE_MANAGER") &&
                                     !xafUser.Roles.Any(r => r.Name == "OCABR_ADMIN" ||
                                                              r.Name == "SUPERVISOR");
            }

            var allApps = (await appRepo.GetAllAsync()).ToList();

            // Filter to assigned cases only for CASE_MANAGER
            if (_isCaseManagerView && !string.IsNullOrWhiteSpace(_currentUserId))
            {
                allApps = allApps
                    .Where(a => a.AssignedToStaffId == _currentUserId ||
                                a.AssignedToName == _currentUserId)
                    .ToList();
            }

            var openApps = allApps.Where(a => !ClosedStatuses.Contains(a.Status)).ToList();
            var today = DateTime.UtcNow;

            _totalOpen = openApps.Count;
            _pendingReview = openApps.Count(a => a.Status == ApplicationStatus.SUBMITTED
                                              || a.Status == ApplicationStatus.INCOMPLETE);
            _agingAlerts = openApps.Count(a => (today - a.SubmittedAt).TotalDays > 30);
            _submittedThisMonth = allApps.Count(a =>
                a.SubmittedAt.Year == today.Year && a.SubmittedAt.Month == today.Month);
            _awaitingDealer = openApps.Count(a => a.Status == ApplicationStatus.ACCEPTED);
            _hearingsScheduled = openApps.Count(a => a.Status == ApplicationStatus.HEARING_SCHEDULED);

            _statusBreakdown = openApps
                .GroupBy(a => a.Status.ToString())
                .OrderByDescending(g => g.Count())
                .ToDictionary(g => g.Key, g => g.Count());

            _byType = openApps
                .GroupBy(a => a.ApplicationType.ToString())
                .ToDictionary(g => g.Key, g => g.Count());

            // Recent activity — scoped to assigned cases for CASE_MANAGER
            var allEvents = await eventRepo.GetAllAsync();
            if (_isCaseManagerView)
            {
                var myAppIds = allApps.Select(a => a.Id).ToHashSet();
                allEvents = allEvents.Where(e => e.ApplicationId.HasValue && myAppIds.Contains(e.ApplicationId.Value));
            }
            _recentActivity = allEvents
                .OrderByDescending(e => e.EventTimestamp)
                .Take(20)
                .ToList();
        }
        catch (Exception ex)
        {
            _loadError = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }

    private int GetBarWidth(int value)
    {
        if (!_statusBreakdown.Any()) return 0;
        var max = _statusBreakdown.Values.Max();
        return max == 0 ? 0 : (int)Math.Round((double)value / max * 100);
    }

    private string GetStatusBarColor(string status) => status switch
    {
        "SUBMITTED"        => "#ea580c",
        "INCOMPLETE"       => "#d97706",
        "ACCEPTED"         => "#2563eb",
        "DEALER_RESPONDED" => "#7c3aed",
        "HEARING_SCHEDULED"=> "#be185d",
        "HEARING_COMPLETE" => "#0891b2",
        "DECISION_ISSUED"  => "#16a34a",
        _                  => "#94a3b8"
    };

    private string GetEventDotClass(CaseEventType type) => type switch    {
        CaseEventType.STATUS_CHANGE      => "d-dot-dark",
        CaseEventType.DEALER_RESPONDED   => "d-dot-dark",
        CaseEventType.HEARING_SCHEDULED  => "d-dot-mid",
        CaseEventType.DECISION_ISSUED    => "d-dot-dark",
        CaseEventType.DOCUMENT_UPLOADED  => "d-dot-mid",
        CaseEventType.NOTE_ADDED         => "d-dot-light",
        _                                => "d-dot-light"
    };
}
