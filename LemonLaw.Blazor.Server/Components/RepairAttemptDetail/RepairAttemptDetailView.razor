@using LemonLaw.Core.Entities
@using LemonLaw.Core.Enums

<div class="ll-wrap">

    @if (_loading)
    {
        <div class="ll-loading"><span class="ll-spinner"></span><span>Loading repair attempt…</span></div>
    }
    else if (_loadError != null)
    {
        <div class="ll-error-box">@_loadError</div>
    }
    else if (_repair != null)
    {
        var app = _repair.Application;

        @* ── Case Header ──────────────────────────────────────────────────────── *@
        @if (app != null)
        {
            <div class="ll-header">
                <div class="ll-header-left">
                    <p class="ll-case-number">Case @app.CaseNumber</p>
                    <div class="ll-meta-row">
                        <span class="ll-badge ll-badge-@app.Status.ToString().ToLower()">@app.Status.ToString().Replace("_", " ")</span>
                        <span class="ll-meta-item"><span class="ll-meta-label">Type:</span> @app.ApplicationType.ToString().Replace("_", " ")</span>
                        @if (app.SubmittedAt != default)
                        {
                            <span class="ll-meta-item"><span class="ll-meta-label">Submitted:</span> @app.SubmittedAt.ToLocalTime().ToString("MM/dd/yyyy")</span>
                        }
                        <span class="ll-meta-item"><span class="ll-meta-label">Last Activity:</span> @app.LastActivityAt.ToLocalTime().ToString("MM/dd/yyyy")</span>
                    </div>
                </div>
            </div>
        }

        @* ── Repair Attempt Details ───────────────────────────────────────────── *@
        <div class="ll-card">
            <div class="ll-card-head">
                <p class="ll-card-title">Repair Attempt</p>
                <button class="ll-edit-btn" type="button" @onclick="OpenEdit"><EditIcon /> Edit</button>
            </div>
            <div class="ll-card-body">
                <div class="ll-fields ll-fields-3">
                    <div>
                        <p class="ll-field-label">Repair Date</p>
                        <p class="ll-field-value">@_repair.RepairDate.ToString("MM/dd/yyyy")</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Facility Name</p>
                        <p class="ll-field-value">@_repair.RepairFacilityName</p>
                    </div>
                    <div>
                        <p class="ll-field-label">RO Number</p>
                        <p class="ll-field-value @(_repair.RoNumber == null ? "ll-field-empty" : "")">@(_repair.RoNumber ?? "—")</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Mileage at Repair</p>
                        <p class="ll-field-value @(_repair.MileageAtRepair == null ? "ll-field-empty" : "")">@(_repair.MileageAtRepair?.ToString("N0") ?? "—")</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Days Out of Service</p>
                        <p class="ll-field-value @(_repair.DaysOutOfService == null ? "ll-field-empty" : "")">@(_repair.DaysOutOfService?.ToString() ?? "—")</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Repair Successful</p>
                        <p class="ll-field-value">@EnumHelper.BoolBadge(_repair.RepairSuccessful)</p>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(_repair.RepairFacilityAddr))
                {
                    <div style="margin-top:12px;">
                        <p class="ll-field-label">Facility Address</p>
                        <p style="font-size:.875rem;color:#1e293b;line-height:1.6;margin:4px 0 0;">@_repair.RepairFacilityAddr</p>
                    </div>
                }
                @if (!string.IsNullOrWhiteSpace(_repair.DefectsAddressed))
                {
                    <div style="margin-top:12px;">
                        <p class="ll-field-label">Defects Addressed</p>
                        <p style="font-size:.875rem;color:#1e293b;line-height:1.6;margin:4px 0 0;">@_repair.DefectsAddressed</p>
                    </div>
                }
            </div>
        </div>

        @* ── Audit Details ────────────────────────────────────────────────────── *@
        <AuditSection Entity="_repair" />
    }
</div>

@* ── Edit Popup ───────────────────────────────────────────────────────────── *@
<DxPopup @bind-Visible="_showEdit" HeaderText="Edit Repair Attempt" Width="700px" ShowFooter="true" CloseOnOutsideClick="false" Scrollable="true">
    <BodyContentTemplate>
        @if (_form != null)
        {
            <div class="ll-form-row ll-form-row-2">
                <div class="ll-form-group"><label class="ll-form-label">Repair Date *</label><input class="ll-input" type="date" @bind="_form.RepairDate" /></div>
                <div class="ll-form-group"><label class="ll-form-label">Facility Name *</label><input class="ll-input" @bind="_form.RepairFacilityName" /></div>
            </div>
            <div class="ll-form-row ll-form-row-2">
                <div class="ll-form-group"><label class="ll-form-label">Facility Address</label><input class="ll-input" @bind="_form.RepairFacilityAddr" /></div>
                <div class="ll-form-group"><label class="ll-form-label">RO Number</label><input class="ll-input" @bind="_form.RoNumber" /></div>
            </div>
            <div class="ll-form-row ll-form-row-2">
                <div class="ll-form-group"><label class="ll-form-label">Mileage at Repair</label><input class="ll-input" type="number" @bind="_form.MileageAtRepair" /></div>
                <div class="ll-form-group"><label class="ll-form-label">Days Out of Service</label><input class="ll-input" type="number" @bind="_form.DaysOutOfService" /></div>
            </div>
            <div class="ll-form-row"><div class="ll-form-group"><label class="ll-form-label">Defects Addressed</label><textarea class="ll-textarea" @bind="_form.DefectsAddressed"></textarea></div></div>
            <div class="ll-checkbox-row" style="margin-top:4px;">
                <input type="checkbox" id="repair-success" @bind="_form.RepairSuccessful" />
                <label for="repair-success">Repair was successful</label>
            </div>
            @if (_saveError != null) { <div class="ll-alert ll-alert-error" style="margin-top:10px;">@_saveError</div> }
        }
    </BodyContentTemplate>
    <FooterContentTemplate>
        <button class="ll-btn ll-btn-ghost" type="button" @onclick="CloseEdit" disabled="@_saving">Cancel</button>
        <button class="ll-btn ll-btn-primary" type="button" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Saving…" : "Save")</button>
    </FooterContentTemplate>
</DxPopup>
