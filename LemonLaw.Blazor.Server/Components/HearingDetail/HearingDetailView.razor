@using LemonLaw.Core.Entities
@using LemonLaw.Core.Enums

<div class="ll-wrap">

    @if (_loading)
    {
        <div class="ll-loading"><span class="ll-spinner"></span><span>Loading hearing…</span></div>
    }
    else if (_loadError != null)
    {
        <div class="ll-error-box">@_loadError</div>
    }
    else if (_hearing != null)
    {
        var app = _hearing.Application;

        @* ── Case Header ──────────────────────────────────────────────────────── *@
        @if (app != null)
        {
            <div class="ll-header">
                <div class="ll-header-left">
                    <p class="ll-case-number">Case @app.CaseNumber</p>
                    <div class="ll-meta-row">
                        <span class="ll-badge ll-badge-@app.Status.ToString().ToLower()">@app.Status.ToString().Replace("_", " ")</span>
                        <span class="ll-meta-item"><span class="ll-meta-label">Type:</span> @app.ApplicationType.ToString().Replace("_", " ")</span>
                        @if (app.SubmittedAt != default)
                        {
                            <span class="ll-meta-item"><span class="ll-meta-label">Submitted:</span> @app.SubmittedAt.ToLocalTime().ToString("MM/dd/yyyy")</span>
                        }
                        <span class="ll-meta-item"><span class="ll-meta-label">Last Activity:</span> @app.LastActivityAt.ToLocalTime().ToString("MM/dd/yyyy")</span>
                    </div>
                </div>
            </div>
        }

        @* ── Hearing Details ──────────────────────────────────────────────────── *@
        <div class="ll-card">
            <div class="ll-card-head">
                <p class="ll-card-title">Hearing</p>
                <button class="ll-edit-btn" type="button" @onclick="OpenEdit"><EditIcon /> Edit</button>
            </div>
            <div class="ll-card-body">
                <div class="ll-fields ll-fields-3">
                    <div>
                        <p class="ll-field-label">Hearing Date</p>
                        <p class="ll-field-value">@_hearing.HearingDate.ToLocalTime().ToString("MM/dd/yyyy hh:mm tt")</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Format</p>
                        <p class="ll-field-value">@EnumHelper.GetDescription(_hearing.HearingFormat)</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Location / URL</p>
                        <p class="ll-field-value @(_hearing.HearingLocation == null ? "ll-field-empty" : "")">@(_hearing.HearingLocation ?? "—")</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Arbitrator</p>
                        <p class="ll-field-value @(_hearing.ArbitratorName == null ? "ll-field-empty" : "")">@(_hearing.ArbitratorName ?? "—")</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Outcome</p>
                        <p class="ll-field-value">@EnumHelper.GetDescription(_hearing.Outcome)</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Continued To</p>
                        <p class="ll-field-value @(_hearing.ContinuedTo == null ? "ll-field-empty" : "")">@(_hearing.ContinuedTo?.ToLocalTime().ToString("MM/dd/yyyy hh:mm tt") ?? "—")</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Consumer Notified</p>
                        <p class="ll-field-value">@EnumHelper.BoolBadge(_hearing.ConsumerNoticesSent)</p>
                    </div>
                    <div>
                        <p class="ll-field-label">Dealer Notified</p>
                        <p class="ll-field-value">@EnumHelper.BoolBadge(_hearing.DealerNoticesSent)</p>
                    </div>
                </div>
                @if (!string.IsNullOrWhiteSpace(_hearing.OutcomeNotes))
                {
                    <div style="margin-top:12px;">
                        <p class="ll-field-label">Outcome Notes</p>
                        <p style="font-size:.875rem;color:#1e293b;line-height:1.6;margin:4px 0 0;">@_hearing.OutcomeNotes</p>
                    </div>
                }
            </div>
        </div>

        @* ── Audit Details ────────────────────────────────────────────────────── *@
        <AuditSection Entity="_hearing" />
    }
</div>

@* ── Edit Popup ───────────────────────────────────────────────────────────── *@
<DxPopup @bind-Visible="_showEdit" HeaderText="Edit Hearing" Width="700px" ShowFooter="true" CloseOnOutsideClick="false" Scrollable="true">
    <BodyContentTemplate>
        @if (_form != null)
        {
            <div class="ll-form-row ll-form-row-2">
                <div class="ll-form-group"><label class="ll-form-label">Hearing Date &amp; Time *</label><input class="ll-input" type="datetime-local" @bind="_form.HearingDate" /></div>
                <div class="ll-form-group">
                    <label class="ll-form-label">Format</label>
                    <select class="ll-select" @bind="_form.HearingFormat">
                        @foreach (var v in Enum.GetValues<HearingFormat>()) { <option value="@v">@EnumHelper.GetDescription(v)</option> }
                    </select>
                </div>
            </div>
            <div class="ll-form-row ll-form-row-2">
                <div class="ll-form-group"><label class="ll-form-label">Location / URL</label><input class="ll-input" @bind="_form.HearingLocation" /></div>
                <div class="ll-form-group"><label class="ll-form-label">Arbitrator Name</label><input class="ll-input" @bind="_form.ArbitratorName" /></div>
            </div>
            <div class="ll-form-row ll-form-row-2">
                <div class="ll-form-group">
                    <label class="ll-form-label">Outcome</label>
                    <select class="ll-select" @bind="_form.Outcome">
                        @foreach (var v in Enum.GetValues<HearingOutcome>()) { <option value="@v">@EnumHelper.GetDescription(v)</option> }
                    </select>
                </div>
                <div class="ll-form-group"><label class="ll-form-label">Continued To</label><input class="ll-input" type="datetime-local" @bind="_form.ContinuedTo" /></div>
            </div>
            <div class="ll-form-row"><div class="ll-form-group"><label class="ll-form-label">Outcome Notes</label><textarea class="ll-textarea" @bind="_form.OutcomeNotes"></textarea></div></div>
            <div class="ll-form-row ll-form-row-2" style="margin-top:4px;">
                <div class="ll-checkbox-row">
                    <input type="checkbox" id="hearing-consumer" @bind="_form.ConsumerNoticesSent" />
                    <label for="hearing-consumer">Consumer notified</label>
                </div>
                <div class="ll-checkbox-row">
                    <input type="checkbox" id="hearing-dealer" @bind="_form.DealerNoticesSent" />
                    <label for="hearing-dealer">Dealer notified</label>
                </div>
            </div>
            @if (_saveError != null) { <div class="ll-alert ll-alert-error" style="margin-top:10px;">@_saveError</div> }
        }
    </BodyContentTemplate>
    <FooterContentTemplate>
        <button class="ll-btn ll-btn-ghost" type="button" @onclick="CloseEdit" disabled="@_saving">Cancel</button>
        <button class="ll-btn ll-btn-primary" type="button" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Saving…" : "Save")</button>
    </FooterContentTemplate>
</DxPopup>
