@using LemonLaw.Core.Entities
@using LemonLaw.Core.Enums
@using LemonLaw.Application.Repositories
@using Microsoft.Extensions.DependencyInjection

@inject IServiceProvider ServiceProvider

<div class="ll-section-toolbar">
    <input class="ll-search-input" type="search" placeholder="Search defects…" @bind="_search" @bind:event="oninput" />
    <button class="ll-btn ll-btn-ghost ll-btn-sm" type="button" @onclick="OpenNew">+ New</button>
</div>
<div style="padding:0;">
    @if (!_filtered.Any()) { <p class="ll-table-empty">@(_search.Length > 0 ? "No results." : "No defects recorded.")</p> }
    else
    {
        <table class="ll-table">
            <thead><tr><th>Description</th><th>Category</th><th>First Occurrence</th><th>Ongoing</th><th style="width:70px;"></th></tr></thead>
            <tbody>
                @foreach (var item in _filtered.OrderBy(d => d.SortOrder))
                {
                    <tr>
                        <td>@item.DefectDescription</td>
                        <td>@EnumHelper.GetDescription(item.DefectCategory)</td>
                        <td>@item.FirstOccurrenceDate.ToString("MM/dd/yyyy")</td>
                        <td>@EnumHelper.BoolBadge(item.IsOngoing)</td>
                        <td class="ll-action-cell">
                            <button class="ll-row-edit-btn" type="button" title="Edit" @onclick="() => OpenEdit(item)"><EditIcon Size="13" /></button>
                            <button class="ll-row-view-btn" type="button" title="View detail" @onclick="() => OnOpenDetail.InvokeAsync(item.Id)">&#128065;</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

<DxPopup @bind-Visible="_showEdit" HeaderText="@(_editId == null ? "New Defect" : "Edit Defect")" Width="560px" ShowFooter="true" CloseOnOutsideClick="false">
    <BodyContentTemplate>
        @if (_form != null)
        {
            <div class="ll-form-row"><div class="ll-form-group"><label class="ll-form-label">Description *</label><textarea class="ll-textarea" @bind="_form.DefectDescription"></textarea></div></div>
            <div class="ll-form-row ll-form-row-2">
                <div class="ll-form-group">
                    <label class="ll-form-label">Category</label>
                    <select class="ll-select" @bind="_form.DefectCategory">
                        @foreach (var v in Enum.GetValues<DefectCategory>()) { <option value="@v">@EnumHelper.GetDescription(v)</option> }
                    </select>
                </div>
                <div class="ll-form-group"><label class="ll-form-label">First Occurrence Date</label><input class="ll-input" type="date" @bind="_form.FirstOccurrenceDate" /></div>
            </div>
            <div class="ll-checkbox-row" style="margin-top:4px;">
                <input type="checkbox" id="defect-ongoing-@_editId" @bind="_form.IsOngoing" />
                <label for="defect-ongoing-@_editId">Defect is ongoing</label>
            </div>
            @if (_saveError != null) { <div class="ll-alert ll-alert-error" style="margin-top:10px;">@_saveError</div> }
        }
    </BodyContentTemplate>
    <FooterContentTemplate>
        <button class="ll-btn ll-btn-ghost" type="button" @onclick="CloseEdit" disabled="@_saving">Cancel</button>
        <button class="ll-btn ll-btn-primary" type="button" @onclick="SaveAsync" disabled="@_saving">@(_saving ? "Saving…" : "Save")</button>
    </FooterContentTemplate>
</DxPopup>

@code {
    [Parameter] public Guid ApplicationId { get; set; }
    [Parameter] public IEnumerable<Defect>? InitialData { get; set; }
    [Parameter] public EventCallback<int> OnCountChanged { get; set; }
    [Parameter] public EventCallback<Guid> OnOpenDetail { get; set; }
    [Parameter] public int RefreshKey { get; set; }

    private List<Defect> _items = new();
    private string _search = string.Empty;
    private List<Defect> _filtered => string.IsNullOrWhiteSpace(_search)
        ? _items
        : _items.Where(d =>
            d.DefectDescription.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            d.DefectCategory.ToString().Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            d.FirstOccurrenceDate.ToString("MM/dd/yyyy").Contains(_search)).ToList();
    private DefectFormModel? _form;
    private Guid? _editId;
    private bool _showEdit, _saving;
    private string? _saveError;
    private bool _initialized;
    private int _lastRefreshKey = -1;

    protected override void OnParametersSet()
    {
        if (!_initialized || RefreshKey != _lastRefreshKey)
        {
            _items = InitialData?.ToList() ?? new();
            _initialized = true;
            _lastRefreshKey = RefreshKey;
        }
    }

    private void OpenNew() { _editId = null; _form = new(); _saveError = null; _showEdit = true; }
    private void OpenEdit(Defect d) { _editId = d.Id; _form = new(d); _saveError = null; _showEdit = true; }
    private void CloseEdit() { _showEdit = false; _form = null; }

    private async Task SaveAsync()
    {
        if (_form == null) return;
        _saving = true; _saveError = null;
        try
        {
            using var scope = ServiceProvider.CreateScope();
            var repo = scope.ServiceProvider.GetRequiredService<IGenericRepository<Defect>>();
            if (_editId == null) { var e = new Defect { ApplicationId = ApplicationId }; _form.ApplyTo(e); await repo.AddAsync(e); await repo.SaveChangesAsync(); _items.Add(e); }
            else
            {
                var fresh = await repo.GetByIdAsync(_editId.Value);
                if (fresh != null) { _form.ApplyTo(fresh); repo.Update(fresh); await repo.SaveChangesAsync(); var local = _items.FirstOrDefault(x => x.Id == _editId); if (local != null) _form.ApplyTo(local); }
            }
            _showEdit = false;
            await OnCountChanged.InvokeAsync(_items.Count);
        }
        catch (Exception ex) { _saveError = ex.Message; }
        finally { _saving = false; }
    }

    private class DefectFormModel
    {
        public string DefectDescription { get; set; } = string.Empty;
        public DefectCategory DefectCategory { get; set; }
        public DateOnly FirstOccurrenceDate { get; set; } = DateOnly.FromDateTime(DateTime.Today);
        public bool IsOngoing { get; set; }

        public DefectFormModel() { }
        public DefectFormModel(Defect d) { DefectDescription = d.DefectDescription; DefectCategory = d.DefectCategory; FirstOccurrenceDate = d.FirstOccurrenceDate; IsOngoing = d.IsOngoing; }
        public void ApplyTo(Defect d) { d.DefectDescription = DefectDescription; d.DefectCategory = DefectCategory; d.FirstOccurrenceDate = FirstOccurrenceDate; d.IsOngoing = IsOngoing; }
    }
}
