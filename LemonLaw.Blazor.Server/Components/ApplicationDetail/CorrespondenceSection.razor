@using LemonLaw.Core.Entities
@using LemonLaw.Core.Enums

<div class="ll-section-toolbar">
    <input class="ll-search-input" type="search" placeholder="Search correspondence…" @bind="_search" @bind:event="oninput" />
</div>
<div style="padding:0;">
    @if (!_filtered.Any()) { <p class="ll-table-empty">@(_search.Length > 0 ? "No results." : "No correspondence on file.")</p> }
    else
    {
        <table class="ll-table">
            <thead><tr><th>Direction</th><th>Recipient</th><th>Subject</th><th>Sent At</th><th>Delivery</th><th style="width:40px;"></th></tr></thead>
            <tbody>
                @foreach (var item in _filtered.OrderByDescending(c => c.SentAt))
                {
                    <tr>
                        <td>@EnumHelper.GetDescription(item.Direction)</td>
                        <td>@item.RecipientType — @item.RecipientEmail</td>
                        <td>@item.Subject</td>
                        <td>@(item.SentAt?.ToLocalTime().ToString("MM/dd/yyyy hh:mm tt") ?? "—")</td>
                        <td><span class="ll-badge @GetDeliveryClass(item.DeliveryStatus)">@EnumHelper.GetDescription(item.DeliveryStatus)</span></td>
                        <td><button class="ll-row-view-btn" type="button" title="View detail" @onclick="() => OnOpenDetail.InvokeAsync(item.Id)">&#128065;</button></td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public Guid ApplicationId { get; set; }
    [Parameter] public IEnumerable<Correspondence>? InitialData { get; set; }
    [Parameter] public EventCallback<Guid> OnOpenDetail { get; set; }
    [Parameter] public int RefreshKey { get; set; }

    private List<Correspondence> _items = new();
    private string _search = string.Empty;
    private List<Correspondence> _filtered => string.IsNullOrWhiteSpace(_search)
        ? _items
        : _items.Where(c =>
            c.Subject.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            c.RecipientEmail.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            c.Direction.ToString().Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnParametersSet() => _items = InitialData?.ToList() ?? new();

    private string GetDeliveryClass(EmailDeliveryStatus s) => s switch
    {
        EmailDeliveryStatus.DELIVERED => "ll-badge-decision_issued",
        EmailDeliveryStatus.OPENED    => "ll-badge-accepted",
        EmailDeliveryStatus.BOUNCED   => "ll-badge-incomplete",
        EmailDeliveryStatus.FAILED    => "ll-badge-incomplete",
        _                             => "ll-badge-submitted"
    };
}
