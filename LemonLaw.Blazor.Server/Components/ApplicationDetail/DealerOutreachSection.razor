@using LemonLaw.Core.Entities
@using LemonLaw.Core.Enums

<div class="ll-section-toolbar">
    <input class="ll-search-input" type="search" placeholder="Search dealer outreach…" @bind="_search" @bind:event="oninput" />
</div>
<div style="padding:0;">
    @if (!_filtered.Any()) { <p class="ll-table-empty">@(_search.Length > 0 ? "No results." : "No dealer outreach sent.")</p> }
    else
    {
        <table class="ll-table">
            <thead><tr><th>Dealer</th><th>Email</th><th>Type</th><th>Sent At</th><th>Response Deadline</th><th>Status</th><th>Response</th></tr></thead>
            <tbody>
                @foreach (var item in _filtered.OrderByDescending(o => o.SentAt))
                {
                    <tr>
                        <td>@item.DealerName</td>
                        <td>@item.DealerEmail</td>
                        <td>@EnumHelper.GetDescription(item.OutreachType)</td>
                        <td>@(item.SentAt?.ToLocalTime().ToString("MM/dd/yyyy hh:mm tt") ?? "—")</td>
                        <td>@item.ResponseDeadline.ToString("MM/dd/yyyy")</td>
                        <td><span class="ll-badge @GetStatusClass(item.Status)">@EnumHelper.GetDescription(item.Status)</span></td>
                        <td>@(item.Response != null ? "Received" : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public Guid ApplicationId { get; set; }
    [Parameter] public IEnumerable<DealerOutreach>? InitialData { get; set; }

    private List<DealerOutreach> _items = new();
    private string _search = string.Empty;
    private List<DealerOutreach> _filtered => string.IsNullOrWhiteSpace(_search)
        ? _items
        : _items.Where(o =>
            o.DealerName.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            o.DealerEmail.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            o.Status.ToString().Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            o.OutreachType.ToString().Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnParametersSet() => _items = InitialData?.ToList() ?? new();

    private string GetStatusClass(OutreachStatus s) => s switch
    {
        OutreachStatus.RESPONDED => "ll-badge-decision_issued",
        OutreachStatus.OVERDUE   => "ll-badge-incomplete",
        OutreachStatus.SENT      => "ll-badge-accepted",
        OutreachStatus.OPENED    => "ll-badge-dealer_responded",
        OutreachStatus.CLOSED    => "ll-badge-withdrawn",
        _                        => "ll-badge-submitted"
    };
}
