@using LemonLaw.Core.Entities
@using LemonLaw.Core.Enums

<div class="ll-card-head" style="border-top:1px solid #f1f5f9;">
    <p class="ll-card-title">Dealer Outreach (@_items.Count)</p>
</div>
<div style="padding:0;">
    @if (!_items.Any()) { <p class="ll-table-empty">No dealer outreach sent.</p> }
    else
    {
        <table class="ll-table">
            <thead><tr><th>Dealer</th><th>Email</th><th>Type</th><th>Sent At</th><th>Response Deadline</th><th>Status</th><th>Response</th></tr></thead>
            <tbody>
                @foreach (var item in _items.OrderByDescending(o => o.SentAt))
                {
                    <tr>
                        <td>@item.DealerName</td>
                        <td>@item.DealerEmail</td>
                        <td>@item.OutreachType</td>
                        <td>@(item.SentAt?.ToLocalTime().ToString("MM/dd/yyyy hh:mm tt") ?? "—")</td>
                        <td>@item.ResponseDeadline.ToString("MM/dd/yyyy")</td>
                        <td><span class="ll-badge @GetStatusClass(item.Status)">@item.Status</span></td>
                        <td>@(item.Response != null ? "Received" : "—")</td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>

@code {
    [Parameter] public Guid ApplicationId { get; set; }
    [Parameter] public IEnumerable<DealerOutreach>? InitialData { get; set; }

    private List<DealerOutreach> _items = new();

    protected override void OnParametersSet() => _items = InitialData?.ToList() ?? new();

    private string GetStatusClass(OutreachStatus s) => s switch
    {
        OutreachStatus.RESPONDED => "ll-badge-decision_issued",
        OutreachStatus.OVERDUE   => "ll-badge-incomplete",
        OutreachStatus.SENT      => "ll-badge-accepted",
        OutreachStatus.OPENED    => "ll-badge-dealer_responded",
        OutreachStatus.CLOSED    => "ll-badge-withdrawn",
        _                        => "ll-badge-submitted"
    };
}
