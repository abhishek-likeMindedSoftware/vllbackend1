@using LemonLaw.Core.Entities
@using LemonLaw.Core.Enums

<div class="ll-section-toolbar">
    <input class="ll-search-input" type="search" placeholder="Search timeline…" @bind="_search" @bind:event="oninput" />
</div>
<div class="ll-card-body">
    @if (!_filtered.Any()) { <p class="ll-field-empty">@(_search.Length > 0 ? "No results." : "No events recorded.")</p> }
    else
    {
        <div class="ll-timeline">
            @foreach (var item in _filtered.OrderByDescending(e => e.EventTimestamp))
            {
                <div class="ll-tl-item">
                    <span class="ll-tl-dot" style="background:@GetDotColor(item.EventType);"></span>
                    <div class="ll-tl-body">
                        <p class="ll-tl-desc">@item.Description</p>
                        <p class="ll-tl-meta">
                            @item.ActorDisplayName &nbsp;·&nbsp;
                            @item.EventTimestamp.ToLocalTime().ToString("MMM d, yyyy h:mm tt") &nbsp;·&nbsp;
                            @item.EventType.ToString().Replace("_", " ")
                        </p>
                        @if (item.PreviousValue != null || item.NewValue != null)
                        {
                            <p class="ll-tl-meta" style="margin-top:2px;">
                                @if (item.PreviousValue != null) { <span>From: @item.PreviousValue</span> }
                                @if (item.NewValue != null) { <span>&nbsp;→ @item.NewValue</span> }
                            </p>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    [Parameter] public IEnumerable<CaseEvent>? InitialData { get; set; }
    [Parameter] public int RefreshKey { get; set; }

    private List<CaseEvent> _items = new();
    private string _search = string.Empty;
    private List<CaseEvent> _filtered => string.IsNullOrWhiteSpace(_search)
        ? _items
        : _items.Where(e =>
            e.Description.Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            (e.ActorDisplayName ?? "").Contains(_search, StringComparison.OrdinalIgnoreCase) ||
            e.EventType.ToString().Contains(_search, StringComparison.OrdinalIgnoreCase)).ToList();

    protected override void OnParametersSet() => _items = InitialData?.ToList() ?? new();

    private string GetDotColor(CaseEventType t) => t switch
    {
        CaseEventType.STATUS_CHANGE      => "#ea580c",
        CaseEventType.DECISION_ISSUED    => "#16a34a",
        CaseEventType.HEARING_SCHEDULED  => "#7c3aed",
        CaseEventType.DEALER_RESPONDED   => "#2563eb",
        CaseEventType.DOCUMENT_UPLOADED  => "#0891b2",
        CaseEventType.DOCUMENT_ACCEPTED  => "#16a34a",
        CaseEventType.DOCUMENT_REJECTED  => "#dc2626",
        CaseEventType.NOTE_ADDED         => "#94a3b8",
        _                                => "#cbd5e1"
    };
}
