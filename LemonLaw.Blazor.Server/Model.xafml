<?xml version="1.0" encoding="utf-8"?>
<Application>
  <NavigationItems NavigationStyle="Accordion">
    <Items>
      <Item Id="Dashboard_Nav" Caption="Dashboard" ImageName="BO_Dashboard" Index="0" ViewId="AdminDashboard_DetailView" IsNewNode="True" />
      <Item Id="Case Management" ImageName="BO_Document" Index="1">
        <Items>
          <Item Id="VllApplication_ListView" Index="0" />
        </Items>
      </Item>
      <Item Id="Dealer Portal Activity" ImageName="BO_StateMachine" Index="2" />
      <Item Id="Default" ImageName="BO_Role" Index="3" />
      <Item Id="Hearings" ImageName="State_Priority_Normal" Index="4" />
      <Item Id="Reports" ImageName="BO_Report" Index="5">
        <Items>
          <Item Id="Dashboards" Visible="False" />
        </Items>
      </Item>
      <Item Id="Utility" ImageName="LayoutCustomization_Item" Index="6" />
      <Item Id="Administration" Visible="False" />
    </Items>
  </NavigationItems>
  <Options UIType="TabbedMDI" FormStyle="Standard" RestoreTabbedMdiLayout="False" ShowTabImage="True" VirtualScrollingEnabled="True" />
  <SchemaModules>
    <SchemaModule Name="SystemModule" Version="25.2.6.0" IsNewNode="True" />
  </SchemaModules>
  <Views>

    <!-- ── Dashboard ──────────────────────────────────────────────────────── -->
    <DetailView Id="AdminDashboard_DetailView" Caption="Dashboard" IsNewNode="True">
      <Actions Id="Actions" IsNewNode="True" />
      <Items IsNewNode="True">
        <PropertyEditor Id="Title" PropertyName="Title" AllowEdit="False" PropertyEditorType="LemonLaw.Blazor.Server.Editors.DashboardPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
      <Layout IsNewNode="True">
        <LayoutGroup Id="Main" IsNewNode="True">
          <LayoutGroup Id="SimpleEditors" RelativeSize="100" IsNewNode="True">
            <LayoutGroup Id="AdminDashboard" Caption="AdminDashboard" RelativeSize="100" IsNewNode="True">
              <LayoutItem Id="Title" Index="0" RelativeSize="100" ShowCaption="False" ViewItem="Title" IsNewNode="True" />
            </LayoutGroup>
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
    </DetailView>

    <!-- ── DealerResponse (pre-existing, keep as-is) ──────────────────────── -->
    <DetailView Id="DealerResponse_DetailView" IsNewNode="True">
      <Actions Id="Actions" IsNewNode="True" />
      <Items IsNewNode="True">
        <PropertyEditor Id="CertificationAccepted" PropertyName="CertificationAccepted" IsNewNode="True" />
        <PropertyEditor Id="CertifierFullName" PropertyName="CertifierFullName" IsNewNode="True" />
        <PropertyEditor Id="DealerPosition" PropertyName="DealerPosition" IsNewNode="True" />
        <PropertyEditor Id="RepairHistoryNotes" PropertyName="RepairHistoryNotes" IsNewNode="True" />
        <PropertyEditor Id="ResponderEmail" PropertyName="ResponderEmail" IsNewNode="True" />
        <PropertyEditor Id="ResponderName" PropertyName="ResponderName" IsNewNode="True" />
        <PropertyEditor Id="ResponderPhone" PropertyName="ResponderPhone" IsNewNode="True" />
        <PropertyEditor Id="ResponderTitle" PropertyName="ResponderTitle" IsNewNode="True" />
        <PropertyEditor Id="ResponseNarrative" PropertyName="ResponseNarrative" IsNewNode="True" />
        <PropertyEditor Id="SettlementDetails" PropertyName="SettlementDetails" IsNewNode="True" />
        <PropertyEditor Id="SettlementOffer" PropertyName="SettlementOffer" IsNewNode="True" />
        <PropertyEditor Id="SubmittedAt" PropertyName="SubmittedAt" IsNewNode="True" />
      </Items>
    </DetailView>

    <!-- ── Custom Blazor detail views — Items only, Layout auto-generated ─── -->
    <!-- XAF auto-lays out the single visible DetailPanel property at 100%.    -->
    <!-- The explicit Layout blocks are not needed since all other properties  -->
    <!-- are marked [VisibleInDetailView(false)] on the entity classes.        -->

    <DetailView Id="VllApplication_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.ApplicationDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

    <DetailView Id="Decision_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.DecisionDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

    <DetailView Id="Defect_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.DefectDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

    <DetailView Id="RepairAttempt_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.RepairAttemptDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

    <DetailView Id="Expense_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.ExpenseDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

    <DetailView Id="Hearing_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.HearingDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

    <DetailView Id="ApplicationDocument_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.DocumentDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

    <DetailView Id="Correspondence_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.CorrespondenceDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

    <DetailView Id="DealerOutreach_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.DealerOutreachDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

    <DetailView Id="CaseNote_DetailView" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="DetailPanel" PropertyName="DetailPanel" PropertyEditorType="LemonLaw.Blazor.Server.Editors.CaseNoteDetailPropertyEditor" Caption="" IsNewNode="True" />
      </Items>
    </DetailView>

  </Views>
</Application>
