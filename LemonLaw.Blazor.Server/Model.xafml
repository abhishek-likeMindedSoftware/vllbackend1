<?xml version="1.0" encoding="utf-8"?>
<Application>
  <NavigationItems NavigationStyle="Accordion">
    <Items>
      <!-- Dashboard — top-level, above Case Management, opens the custom dashboard component -->
      <Item Id="Dashboard_Nav" Caption="Dashboard" ImageName="BO_Dashboard" Index="0" ViewId="AdminDashboard_DetailView" IsNewNode="True" />
      <Item Id="Administration" Visible="False" />
      <Item Id="Dashboard_Group" Visible="False" />
      <Item Id="Case Management" ImageName="BO_Document" Index="1" />
      <Item Id="Dealer Portal Activity" ImageName="BO_StateMachine" Index="2" />
      <Item Id="Default" ImageName="BO_Role" Index="3" />
      <Item Id="Hearings" ImageName="State_Priority_Normal" Index="4" />
      <Item Id="Reports" ImageName="BO_Report" Index="5">
        <Items>
          <Item Id="DashboardData_ListView" Visible="False" />
          <Item Id="Dashboards" Visible="False" />
        </Items>
      </Item>
      <Item Id="Utility" ImageName="LayoutCustomization_Item" Index="6" />
    </Items>
  </NavigationItems>
  <Options UIType="TabbedMDI" FormStyle="Standard" RestoreTabbedMdiLayout="False" ShowTabImage="True" VirtualScrollingEnabled="True" />
  <SchemaModules>
    <SchemaModule Name="SystemModule" Version="25.2.6.0" IsNewNode="True" />
  </SchemaModules>
  <Views>
    <!-- Custom dashboard detail view — renders the Dashboard Blazor component via DashboardPropertyEditor -->
    <DetailView Id="AdminDashboard_DetailView" Caption="Dashboard" IsNewNode="True">
      <Items IsNewNode="True">
        <PropertyEditor Id="Title" PropertyName="Title" AllowEdit="False"
                        PropertyEditorType="LemonLaw.Blazor.Server.Editors.DashboardPropertyEditor"
                        Caption="" IsNewNode="True" />
      </Items>
      <Layout IsNewNode="True">
        <LayoutGroup Id="Main" IsNewNode="True">
          <LayoutGroup Id="SimpleEditors" RelativeSize="100" IsNewNode="True">
            <LayoutGroup Id="AdminDashboard" Caption="AdminDashboard" RelativeSize="100" IsNewNode="True">
              <LayoutItem Id="Title" ViewItem="Title" Index="0" RelativeSize="100" ShowCaption="False" IsNewNode="True" />
            </LayoutGroup>
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
    </DetailView>
    <DetailView Id="AuditDetails_DetailView">
      <Layout>
        <LayoutGroup Id="Main" RelativeSize="100">
          <LayoutGroup Id="SimpleEditors" RelativeSize="100">
            <LayoutGroup Id="AuditDetails" RelativeSize="100">
              <LayoutGroup Id="Item1" ShowCaption="True" Caption="Audit Details" CaptionLocation="Top" Index="0" RelativeSize="100" Direction="Horizontal" IsNewNode="True">
                <LayoutGroup Id="Autoc9a5288e-dc58-4402-be30-57d19bca9e64" ShowCaption="False" Caption="" Index="0" RelativeSize="49.94400895856663" IsNewNode="True">
                  <LayoutItem Id="CreatedDate" ViewItem="CreatedDate" Index="0" RelativeSize="5.247813411078718" IsNewNode="True" />
                  <LayoutItem Id="CreatedBy" ViewItem="CreatedBy" Index="1" RelativeSize="94.75218658892128" IsNewNode="True" />
                </LayoutGroup>
                <LayoutGroup Id="Autofb41f0f2-ceb2-4efa-b49e-72d5866ef584" ShowCaption="False" Caption="" Index="1" RelativeSize="50.05599104143337" IsNewNode="True">
                  <LayoutItem Id="ModifiedDate" ViewItem="ModifiedDate" Index="0" RelativeSize="5.247813411078718" IsNewNode="True" />
                  <LayoutItem Id="ModifiedBy" ViewItem="ModifiedBy" Index="1" RelativeSize="94.75218658892128" IsNewNode="True" />
                </LayoutGroup>
              </LayoutGroup>
            </LayoutGroup>
          </LayoutGroup>
        </LayoutGroup>
      </Layout>
    </DetailView>
  </Views>
</Application>
