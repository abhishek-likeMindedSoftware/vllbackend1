<?xml version="1.0" encoding="utf-8"?>
<Application>
  <NavigationItems NavigationStyle="Accordion">
    <Items>
      <Item Id="Dashboard_Nav" Caption="Dashboard" ImageName="BO_Dashboard" Index="0" ViewId="AdminDashboard_DetailView" IsNewNode="True" />
      <Item Id="Case Management" ImageName="BO_Document" Index="1">
        <Items>
          <Item Id="VllApplication_ListView" Index="0" />
        </Items>
      </Item>
      <Item Id="Dealer Portal Activity" ImageName="BO_StateMachine" Index="2" />
